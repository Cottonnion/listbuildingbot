# ============================================================
# ListBuildingBot WordPress Plugin — .gitignore
# ============================================================

# --- Composer dependencies ---
# Run `composer install` after cloning to restore these.
/vendor/

# --- OS junk ---
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
desktop.ini

# --- IDE / Editor ---
.idea/
.vscode/
*.sublime-project
*.sublime-workspace
nbproject/
*.swp
*.swo
*~

# --- Node / npm (if ever used) ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock

# --- Build / dist artifacts ---
*.zip
*.tar.gz
dist/
build/

# --- Logs ---
*.log
debug.log

# --- WordPress local config (should never be committed) ---
wp-config.php
wp-config-local.php

# --- PHP temp / cache ---
*.cache
.phpunit.result.cache

# --- Environment files ---
.env
.env.local
.env.*.local

# --- PHPStan / static analysis ---
phpstan.neon
.phpstan/

# --- Sass / CSS build artifacts ---
*.css.map
*.js.map
